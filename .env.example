# Core
NODE_ENV=development
LOG_LEVEL=info

# Database (Supabase connection string)
# Find this in: Supabase Dashboard → Project Settings → Database → Connection String → URI
# Use the "Transaction" pooler (port 6543) for apps, direct (5432) for migrations
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Security
JWT_ISSUER=agent-optima
JWT_AUDIENCE=agent-optima-api
JWT_SECRET=replace-with-a-32-char-min-random-secret

# Provider adapter: mock (no real LLM calls) | openai
PROVIDER_ADAPTER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Worker tuning
POLL_INTERVAL_MS=1000
VISIBILITY_TIMEOUT_SECS=30
MAX_RETRIES=3
