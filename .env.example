# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ── Database ─────────────────────────────────────────────────────────────────
# Docker-compose (internal): postgresql://optima:changeme@postgres:5432/agentoptima
# Supabase / external:       postgresql://postgres.[ref]:[pass]@host:5432/postgres
DATABASE_URL=postgresql://optima:changeme@postgres:5432/agentoptima

# disable  → plain TCP (Docker-internal Postgres, local dev)
# require  → TLS required (Supabase, RDS, any cloud DB)
DATABASE_SSL=disable

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_ISSUER=agent-optima
JWT_AUDIENCE=agent-optima-api
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32-output

# ── Web dashboard ────────────────────────────────────────────────────────────
# URL of control-api as seen by the browser (used at Vite build time)
VITE_API_URL=http://localhost:3001

# ── Provider adapter ─────────────────────────────────────────────────────────
# mock (no real LLM calls) | openai
PROVIDER_ADAPTER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Worker tuning ─────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=1000
VISIBILITY_TIMEOUT_SECS=30
MAX_RETRIES=3

# ── Postgres password (docker-compose only) ───────────────────────────────────
POSTGRES_PASSWORD=changeme
